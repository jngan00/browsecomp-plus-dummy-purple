{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/rdi-foundation/browsecomp-plus-dummy-purple:latest",
    entrypoint: "./entrypoint.sh --host 0.0.0.0 --port 9009",
    env: {
      PYTHONUNBUFFERED: "1",
      // HuggingFace token for faster index downloads.
      HF_TOKEN: "${config.hf_token}",
      // Set to "true" to skip the BM25 index download. Retrieval will return
      // no results, but the agent still exercises the full A2A pipeline.
      SKIP_INDEX_DOWNLOAD: "${config.skip_index_download}",
    },
    network: {
      endpoints: [
        { name: "a2a", port: 9009 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      hf_token: { type: "string" },
      skip_index_download: { type: "string" },
    },
    required: [],
    additionalProperties: false,
  },
  slots: {
    // Gateway proxy — allows the Amber gateway to route green's outbound
    // calls back through the mesh to this agent.
    proxy: { kind: "a2a", optional: true },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a" },
  },
  exports: { a2a: "a2a" },
}
